{
  "name": "OpenFactory-SDK Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".",
    "args": {
      "USERNAME": "vscode",
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:3.1.0": {},
    "./features/infra": {
      "useLocalSdk": true,
      "openfactory-version": "main"
    },
    "./features/connectors": {
      "useLocalSdk": true,
      "shdr-coordinator-version": "latest",
      "shdr-gateway-version": "latest",
      "opcua-coordinator-version": "latest",
      "opcua-gateway-version": "latest"
    },
    "./features/nfs-server": {}
  },
  "containerEnv": {
    "ENVIRONMENT": "local",
    "OPENFACTORY_UNS_SCHEMA": "/workspaces/openfactory-sdk/.devcontainer/uns.yml"
  },
  "forwardPorts": [80],
  "portsAttributes": {
    "80": {
      "label": "Traefik",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "pip install -e /workspaces/openfactory-sdk[dev]",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash-login",
        "terminal.integrated.profiles.linux": {
          "bash-login": {
            "path": "/bin/bash",
            "args": ["-l"]
          }
        }
      },
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
